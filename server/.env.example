# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@ep-example-123456.us-east-2.aws.neon.tech/nexide?sslmode=require

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Security
COOKIE_SECRET=your-super-secret-key-minimum-32-characters-long

# JWT
JWT_ACCESS_SECRET=your-jwt-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=your-jwt-refresh-secret-minimum-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# AI — Providers (tried in priority order)
# 1. Gemini (free) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# 2. Groq Cloud (free, fast) — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# 3. OpenRouter (free models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05

# 4. Mistral AI (free tier) — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# One provider enough hai — fallback chain auto hai
# Sirf jinke API key doge wahi register honge

# Logging
LOG_LEVEL=info
